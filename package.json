{
  "name": "claude-session-manager",
  "displayName": "Claude Session Manager",
  "description": "Named session manager for Claude Code and Codex CLI — save, name, and resume sessions from a sidebar panel",
  "version": "1.2.2",
  "publisher": "conglyu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/medialord/claude-session-manager"
  },
  "bugs": {
    "url": "https://github.com/medialord/claude-session-manager/issues"
  },
  "keywords": [
    "claude-code",
    "claude",
    "codex",
    "openai",
    "session",
    "conversation",
    "productivity"
  ],
  "icon": "resources/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:claudeSessionsNamed",
    "onView:claudeSessionsRecent"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Claude Session Manager",
      "properties": {
        "claudeSessionManager.claudePath": {
          "type": "string",
          "default": "",
          "description": "Path to the claude CLI binary. Auto-detected if empty (checks: VS Code terminal PATH → Homebrew → /usr/local)."
        },
        "claudeSessionManager.codexPath": {
          "type": "string",
          "default": "",
          "description": "Path to the codex CLI binary. Auto-detected if empty (checks: VS Code terminal PATH → Homebrew → /usr/local)."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claude-sessions",
          "title": "AI Sessions",
          "icon": "$(comment-discussion)"
        }
      ]
    },
    "views": {
      "claude-sessions": [
        {
          "id": "claudeSessionsNamed",
          "name": "Named",
          "contextualTitle": "Named Sessions"
        },
        {
          "id": "claudeSessionsRecent",
          "name": "Recent",
          "contextualTitle": "Recent Sessions"
        }
      ]
    },
    "commands": [
      {
        "command": "claude-sessions.refresh",
        "title": "Refresh Sessions",
        "icon": "$(refresh)"
      },
      {
        "command": "claude-sessions.nameSession",
        "title": "Name This Session",
        "icon": "$(edit)"
      },
      {
        "command": "claude-sessions.renameSession",
        "title": "Rename Session",
        "icon": "$(edit)"
      },
      {
        "command": "claude-sessions.resumeSession",
        "title": "Resume Session",
        "icon": "$(play)"
      },
      {
        "command": "claude-sessions.deleteName",
        "title": "Remove Name",
        "icon": "$(close)"
      },
      {
        "command": "claude-sessions.copyResumeCommand",
        "title": "Copy Resume Command",
        "icon": "$(copy)"
      },
      {
        "command": "claude-sessions.openSessionFolder",
        "title": "Open Session File",
        "icon": "$(folder-opened)"
      },
      {
        "command": "claude-sessions.switchTool",
        "title": "Switch Tool (Claude ↔ Codex)",
        "icon": "$(arrow-swap)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "claude-sessions.switchTool",
          "when": "view == claudeSessionsNamed || view == claudeSessionsRecent",
          "group": "navigation@1"
        },
        {
          "command": "claude-sessions.refresh",
          "when": "view == claudeSessionsNamed || view == claudeSessionsRecent",
          "group": "navigation@2"
        },
        {
          "command": "claude-sessions.nameSession",
          "when": "view == claudeSessionsRecent",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "claude-sessions.resumeSession",
          "when": "viewItem == named-claude || viewItem == unnamed-claude || viewItem == named-codex || viewItem == unnamed-codex",
          "group": "inline@1"
        },
        {
          "command": "claude-sessions.deleteName",
          "when": "viewItem == named-claude || viewItem == named-codex",
          "group": "inline@2"
        },
        {
          "command": "claude-sessions.renameSession",
          "when": "viewItem == named-claude || viewItem == named-codex",
          "group": "navigation@1"
        },
        {
          "command": "claude-sessions.nameSession",
          "when": "viewItem == unnamed-claude || viewItem == unnamed-codex",
          "group": "navigation@1"
        },
        {
          "command": "claude-sessions.deleteName",
          "when": "viewItem == named-claude || viewItem == named-codex",
          "group": "navigation@2"
        },
        {
          "command": "claude-sessions.copyResumeCommand",
          "when": "viewItem == named-claude || viewItem == unnamed-claude || viewItem == named-codex || viewItem == unnamed-codex",
          "group": "navigation@3"
        },
        {
          "command": "claude-sessions.openSessionFolder",
          "when": "viewItem == named-claude || viewItem == unnamed-claude || viewItem == named-codex || viewItem == unnamed-codex",
          "group": "navigation@4"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "install-extension": "code --install-extension claude-session-manager-1.2.2.vsix"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
